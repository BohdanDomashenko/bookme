// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"

    // Optional Prisma Client Generator configuration
  runtime                = "nodejs" // <-- Important part 2
  moduleFormat           = "cjs"
  generatedFileExtension = "ts" // <-- Important part 3
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid(7))
  fullName String @db.VarChar(100) @map("full_name")
  email String @unique @db.VarChar(100)
  phone String? @db.VarChar(100)
  country Country @relation(fields: [countryCode], references: [code])
  countryCode String @db.VarChar(2) @map("country_code")
  role UserRole @default(USER)
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  
  propertyBookings PropertyBooking[]
  otp UserOTP?
}

model UserOTP { 
  id String @id @default(uuid(7))
  code String @db.VarChar(6)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id") @unique()
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
}

model Property {
  id String @id @default(uuid(7))
  title String
  status PropertyStatus
  description String?
  // cents
  price Int
  country Country @relation(fields: [countryCode], references: [code])
  countryCode String @db.VarChar(2) @map("country_code")
  city String @db.VarChar(100)
  address String @db.VarChar(100)
  mainImage String @db.VarChar(100) @map("main_image")
  images String[] @db.VarChar(100)
  bookings PropertyBooking[]
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([status, countryCode, city, price])
}

model PropertyBooking {
  id String @id @default(uuid(7))
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String @map("property_id")
  checkIn DateTime @map("check_in")
  checkOut DateTime @map("check_out")
  guestsCount Int @map("guests_count")
  status PropertyBookingStatus
  paymentStatus PropertyBookingPaymentStatus @map("payment_status")

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([propertyId, checkIn, checkOut])

  @@map("property_bookings")
}

model Country {
  code String @id @db.VarChar(2)
  name String @db.VarChar(100)

  properties Property[]
  users User[]
}

enum PaymentProvider {
  STRIPE
}
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}
enum PaymentResourceType {
  PROPERTY_BOOKING
}
model Payment {
  id String @id @default(uuid(7))
  provider PaymentProvider
  providerPaymentId String @map("provider_payment_id") @db.VarChar(100)
  resourceType PaymentResourceType @map("resource_type")
  resourceId String @map("resource_id") @db.VarChar(100)
  amount Int // cents
  currency String @db.VarChar(10)
  status PaymentStatus @default(PENDING)
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  
  @@unique([provider, providerPaymentId])
  @@index([resourceType, resourceId])
  @@map("payments")
}


model StripeWebhookEvent {
  id           String   @id @default(uuid(7))
  eventId      String   @unique @map("event_id") // Stripe event.id (global dedupe)
  type         String
  payload      Json
  status       String   @default("pending") // pending | processing | processed | failed
  processedAt  DateTime? @map("processed_at")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
}

enum UserRole {
  ADMIN
  USER
}

enum PropertyStatus {
  ACTIVE
  DISABLED
}

enum PropertyBookingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PropertyBookingPaymentStatus {
  PENDING
  PAID
}